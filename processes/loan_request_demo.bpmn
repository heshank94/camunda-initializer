  <bpmn:process id="loan_request_demo" name="Loan Request" isExecutable="true">
    <bpmn:documentation>This is done mainly for demonstration purposes</bpmn:documentation>
    <bpmn:extensionElements>
      <zeebe:versionTag value="0.0.3" />
    </bpmn:extensionElements>
    <bpmn:startEvent id="Event_049lk4e" name="Start Event">
      <bpmn:outgoing>Flow_12xhfm3</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="lead-generation" name="Lead Generation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="lead_generation" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_12xhfm3</bpmn:incoming>
      <bpmn:outgoing>Flow_1jdlfrf</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_12xhfm3" sourceRef="Event_049lk4e" targetRef="lead-generation" />
    <bpmn:intermediateCatchEvent id="fo-task-assignment" name="Wait - LO Task Assignment">
      <bpmn:incoming>Flow_1jdlfrf</bpmn:incoming>
      <bpmn:outgoing>Flow_1gw8pix</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0wty22u" messageRef="Message_0vamudn" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1jdlfrf" sourceRef="lead-generation" targetRef="fo-task-assignment" />
    <bpmn:serviceTask id="notify-task-assigned" name="Notify Task Assigned">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notify_task_assigned" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1gw8pix</bpmn:incoming>
      <bpmn:outgoing>Flow_11e6yh6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1gw8pix" sourceRef="fo-task-assignment" targetRef="notify-task-assigned" />
    <bpmn:intermediateCatchEvent id="fo-task-started" name="Wait - FO Task  Started">
      <bpmn:incoming>Flow_11e6yh6</bpmn:incoming>
      <bpmn:outgoing>Flow_0qbydg2</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_09n68ef" messageRef="Message_38ngf1v" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_11e6yh6" sourceRef="notify-task-assigned" targetRef="fo-task-started" />
    <bpmn:serviceTask id="notify-visit-started" name="Notify Visit Started">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notify_visit_started" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0qbydg2</bpmn:incoming>
      <bpmn:outgoing>Flow_1bh07ai</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0qbydg2" sourceRef="fo-task-started" targetRef="notify-visit-started" />
    <bpmn:intermediateCatchEvent id="fo-task-completed" name="Wait - FO Task  Completed">
      <bpmn:incoming>Flow_1bh07ai</bpmn:incoming>
      <bpmn:outgoing>Flow_1ivdbjn</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1oo6jpz" messageRef="Message_2ir7itq" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_1bh07ai" sourceRef="notify-visit-started" targetRef="fo-task-completed" />
    <bpmn:serviceTask id="sync-task-and-visit-information" name="Sync Task And Visit Information">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="sync_task_and_visit_information" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ivdbjn</bpmn:incoming>
      <bpmn:outgoing>Flow_03kks4v</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1ivdbjn" sourceRef="fo-task-completed" targetRef="sync-task-and-visit-information" />
    <bpmn:intermediateCatchEvent id="lo-decision" name="Wait - LO Decision">
      <bpmn:incoming>Flow_03kks4v</bpmn:incoming>
      <bpmn:outgoing>Flow_1udnzqn</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0gt7dcm" messageRef="Message_0pfg99s" />
    </bpmn:intermediateCatchEvent>
    <bpmn:sequenceFlow id="Flow_03kks4v" sourceRef="sync-task-and-visit-information" targetRef="lo-decision" />
    <bpmn:exclusiveGateway id="Gateway_0zo2y84">
      <bpmn:incoming>Flow_1udnzqn</bpmn:incoming>
      <bpmn:outgoing>Flow_1i0i26q</bpmn:outgoing>
      <bpmn:outgoing>Flow_00gqk5d</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1udnzqn" sourceRef="lo-decision" targetRef="Gateway_0zo2y84" />
    <bpmn:serviceTask id="loan-approved" name="Loan Approved">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan_approved" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1i0i26q</bpmn:incoming>
      <bpmn:outgoing>Flow_1yw3ste</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1i0i26q" sourceRef="Gateway_0zo2y84" targetRef="loan-approved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=LO_DECISION = "Approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="loan-rejected" name="Loan Rejected">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan_rejected" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_00gqk5d</bpmn:incoming>
      <bpmn:outgoing>Flow_06gf5me</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_00gqk5d" sourceRef="Gateway_0zo2y84" targetRef="loan-rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=LO_DECISION = "Rejected"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_1iniy0c">
      <bpmn:incoming>Flow_1yw3ste</bpmn:incoming>
      <bpmn:incoming>Flow_06gf5me</bpmn:incoming>
      <bpmn:outgoing>Flow_0anhd6l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1yw3ste" sourceRef="loan-approved" targetRef="Gateway_1iniy0c" />
    <bpmn:sequenceFlow id="Flow_06gf5me" sourceRef="loan-rejected" targetRef="Gateway_1iniy0c" />
    <bpmn:endEvent id="Event_1r3qyur" name="End Event">
      <bpmn:incoming>Flow_0anhd6l</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0anhd6l" sourceRef="Gateway_1iniy0c" targetRef="Event_1r3qyur" />
  </bpmn:process>
